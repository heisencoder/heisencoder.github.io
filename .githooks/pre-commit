#!/bin/sh
# Block direct commits to main. `main` is protected on GitHub; this catches the
# mistake locally, before a commit is even created, so work always goes through
# a feature branch + PR.
#
# Enabled automatically via the "prepare" script in package.json
# (git config core.hooksPath .githooks). To bypass intentionally:
#   git commit --no-verify

branch="$(git symbolic-ref --short HEAD 2>/dev/null)"

if [ "$branch" = "main" ]; then
  echo "✖ Refusing to commit directly to 'main'." >&2
  echo "  main is protected — create a feature branch and open a PR instead:" >&2
  echo "    git switch -c my-change" >&2
  echo "  (To override this hook for one commit: git commit --no-verify)" >&2
  exit 1
fi

exit 0
