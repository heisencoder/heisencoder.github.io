---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<section class="section section--tight page-header">
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
  </div>
</section>

<style>
  .page-header {
    padding-top: clamp(2.5rem, 6vw, 4rem);
    border-bottom: 1px solid var(--rule);
  }
</style>
