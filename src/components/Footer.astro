---
import { NAV, SOCIAL, SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__name">
        <span class="prompt">&gt;</span> {SITE.name}
      </p>
      <p class="site-footer__tag">{SITE.tagline}</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <ul>
        {NAV.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        {
          SOCIAL.map((item) => (
            <li>
              <a href={item.href} target="_blank" rel="noopener">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="container site-footer__bar">
    <span>© {year} {SITE.name}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--footer-bg);
    color: var(--footer-ink);
    padding-block: clamp(2.5rem, 5vw, 3.5rem) 1.5rem;
    border-top: 1px solid var(--footer-rule);
  }

  .site-footer__inner {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 40rem) {
    .site-footer__inner {
      grid-template-columns: 1.5fr 1fr;
      align-items: start;
    }
  }

  .site-footer__name {
    font-weight: 700;
    color: var(--footer-heading);
    margin-bottom: 0.4rem;
  }

  .prompt {
    color: var(--accent-cool);
  }

  .site-footer__tag {
    color: var(--footer-ink);
    margin: 0;
  }

  .site-footer__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, max-content);
    gap: 0.5rem 2rem;
  }

  .site-footer__nav a {
    color: var(--footer-ink);
    font-size: 0.95rem;
  }

  .site-footer__nav a:hover {
    color: var(--link-hover);
    border-bottom-color: var(--link-hover);
  }

  .site-footer__bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--footer-rule);
    font-size: 0.88rem;
    color: var(--footer-faint);
  }
</style>
