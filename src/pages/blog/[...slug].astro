---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// One page per markdown file in src/content/blog/. `post.id` is the slug derived
// from the filename (e.g. hello-world.md -> "hello-world").
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await render(post);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="section post">
    <div class="container container--prose">
      <p class="post__back"><a href="/blog/">&larr; All posts</a></p>

      <header class="post__header">
        <p class="post__meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {fmtDate(post.data.pubDate)}
          </time>
          <span class="post__by">{`· ${post.data.author}`}</span>
          {
            post.data.tags.length > 0 && (
              <span class="post__tags">
                {post.data.tags.map((t) => (
                  <span class="tag">#{t}</span>
                ))}
              </span>
            )
          }
        </p>
        <h1>{post.data.title}</h1>
        <p class="lead">{post.data.description}</p>
        {
          post.data.updatedDate && (
            <p class="post__updated">
              Updated {fmtDate(post.data.updatedDate)}
            </p>
          )
        }
      </header>

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .post__back {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .post__header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    color: var(--mint-ink);
  }

  .post__updated {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    color: var(--ink-faint);
  }
</style>
