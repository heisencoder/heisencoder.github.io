---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found" description="The page you were looking for could not be found.">
  <section class="section not-found">
    <div class="container">
      <p class="eyebrow">Error 404</p>
      <pre class="term" aria-hidden="true">$ cat {Astro.url.pathname}
cat: {Astro.url.pathname}: No such file or directory</pre>
      <h1>This page printed nothing.</h1>
      <p class="lead">
        The address you requested isn't on the line. It may have moved, or never
        existed. Let's get you back to something solid.
      </p>
      <div class="actions">
        <a class="btn btn--primary" href="/">Return home</a>
        <a class="btn btn--ghost" href="/blog/">Read the blog</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    padding-block: clamp(4rem, 12vw, 8rem);
  }

  .term {
    background: var(--term-bg);
    color: var(--term-ink);
    border: 1px solid var(--term-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 0.9rem;
    margin: 0 0 1.5rem;
    max-width: 42rem;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1rem;
  }
</style>
